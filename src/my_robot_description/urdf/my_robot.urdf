<?xml version="1.0"?>

<robot name="my_robot">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.3 0.2"/>
      </geometry>
    </visual>
  </link>

  <link name="body"/>

  <joint name="base_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="body"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
  </joint>

</robot>